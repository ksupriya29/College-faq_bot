# Copy this file to .env and fill in your real key. .env is gitignored.

# OpenRouter — used for chat generation and the LLM-as-judge by default.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Models (OpenRouter model slugs)
CHAT_MODEL=openai/gpt-4o-mini
JUDGE_MODEL=openai/gpt-4o
TEST_GEN_MODEL=openai/gpt-4o
EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional: only set these if embeddings need to go straight to OpenAI instead
# of OpenRouter (some OpenRouter accounts don't have embedding-model access).
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# Retrieval / chunking defaults (can also be tuned from the Streamlit sidebar)
CHUNK_SIZE=400
CHUNK_OVERLAP=60
DEFAULT_TOP_K=6
PERFORMANCE_SLA_SECONDS=10

# Governance — named person responsible for updating the grounding document
# (Accountability checklist item). Defaults to the college IT contact.
# GOV_DOCUMENT_OWNER=Dr. J. Manoj Kumar, BVRIT Hyderabad IT Office
# GOV_DOCUMENT_OWNER_CONTACT=phone 92471 64714, email info@bvrithyderabad.edu.in
