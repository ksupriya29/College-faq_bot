.venv/
__pycache__/
*.pyc
.env
vectorstore/
.streamlit/secrets.toml
user_profiles/

# Day 5, Session 3 (Observability) -- raw/query call logs are regenerated
# continuously by every LLM call (see src/observability.py); not evidence to
# track, just an ever-growing local log.
logs/

# Day 5, Session 4 (Governance) -- a separate Python env for Giskard (see
# governance/giskard_scan.py), and raw scan/test outputs regenerated by
# running each framework; GOVERNANCE_REPORT.md and FAIRNESS_AUDIT.md are the
# tracked deliverables (same convention as eval/report.json vs. eval/raw_results.json).
governance/.giskard_venv/
governance/giskard_report.html
governance/giskard_findings.json
governance/giskard_fairness_*.html
governance/giskard_fairness_summary.json
governance/deepeval/results.json
governance/deepeval/bias_pairs_results.json
governance/promptfoo/output/
governance/promptfoo/*.json

# Intermediate eval artifacts are regenerated by eval/run_tests.py, eval/judge.py,
# and eval/ragas_eval.py — keep only the inputs (test_cases.json) and the final
# deliverable (report.json) tracked, since they're evidence of the completed eval.
eval/raw_results.json
eval/judged_results.json
eval/ragas_results.json
desktop.ini
